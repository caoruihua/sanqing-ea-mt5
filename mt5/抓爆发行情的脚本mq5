//+------------------------------------------------------------------+
//|  BoxBreakout_XAUUSD.mq5                                          |
//|  箱体突破 + 30根K线均价止损 + 15分钟强制平仓                       |
//+------------------------------------------------------------------+
#property copyright "BoxBreakout"
#property version   "2.00"
#property strict

#include <Trade\Trade.mqh>

//--- 输入参数
input group "=== 箱体参数 ==="
input int    InpBoxBars        = 30;      // 箱体统计K线数量
input double InpBreakDistance  = 10.0;   // 突破距离(美金)

input group "=== 交易参数 ==="
input double InpLotSize        = 0.01;   // 手数
input int    InpHoldMinutes    = 15;     // 持仓分钟数，到时强制平仓
input double InpMaxBoxHeight   = 25.0;   // only trade compact boxes before breakout
input int    InpMagicNumber    = 20240602;

//--- 全局变量
CTrade trade;
int    lastBarCount = 0;

//+------------------------------------------------------------------+
//| 初始化                                                            |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);
   trade.SetDeviationInPoints(30);
   Print("BoxBreakout v2.0 初始化成功");
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| 主逻辑                                                            |
//+------------------------------------------------------------------+
void OnTick()
{
   // ===== 第一步：检查持仓是否超时 =====
   CheckAndCloseByTime();

   // ===== 第二步：只在新K线时检测信号 =====
   int currentBars = Bars(_Symbol, PERIOD_CURRENT);
   if(currentBars == lastBarCount) return;
   lastBarCount = currentBars;
   Print("新K线触发检测 | 周期=", EnumToString(PERIOD_CURRENT), " | Bars=", currentBars);

   // 已有持仓则不开新单
   int myPositions = CountMyPositions();
   if(myPositions > 0)
   {
      Print("跳过开仓：当前已有持仓 | 持仓数=", myPositions);
      return;
   }

   // ===== 第三步：计算箱体 + 均价止损 =====
   double boxHigh   = -DBL_MAX;
   double boxLow    =  DBL_MAX;
   double sumClose  = 0.0;

   for(int i = 2; i <= InpBoxBars + 1; i++)
   {
      double h = iHigh(_Symbol,  PERIOD_CURRENT, i);
      double l = iLow(_Symbol,   PERIOD_CURRENT, i);
      double c = iClose(_Symbol, PERIOD_CURRENT, i);

      if(h > boxHigh) boxHigh = h;
      if(l < boxLow)  boxLow  = l;
      sumClose += c;
   }

   // 30根K线收盘价均值 = 止损位
   double avgClose = sumClose / InpBoxBars;
   double boxHeight = boxHigh - boxLow;
   Print("箱体统计 | 箱顶=", DoubleToString(boxHigh, _Digits),
         " | 箱底=", DoubleToString(boxLow, _Digits),
         " | 高度=", DoubleToString(boxHeight, 2),
         " | 均价止损=", DoubleToString(avgClose, _Digits),
         " | 统计根数=", InpBoxBars);

   if(boxHeight > InpMaxBoxHeight)
   {
      Print("跳过信号：箱体过宽，不视为震荡 | 箱体高度=", DoubleToString(boxHeight, 2),
            " | 允许最大高度=", DoubleToString(InpMaxBoxHeight, 2));
      return;
   }

   // ===== 第四步：获取最新收盘价 =====
   double lastClose = iClose(_Symbol, PERIOD_CURRENT, 1);
   Print("突破检测 | 最新收盘=", DoubleToString(lastClose, _Digits),
         " | 向上触发价=", DoubleToString(boxHigh + InpBreakDistance, _Digits),
         " | 向下触发价=", DoubleToString(boxLow - InpBreakDistance, _Digits),
         " | 突破距离=", DoubleToString(InpBreakDistance, 2));

   // ===== 第五步：判断突破方向 =====
   bool bullBreak = (lastClose > boxHigh + InpBreakDistance);
   bool bearBreak = (lastClose < boxLow  - InpBreakDistance);
   if(!bullBreak && !bearBreak)
      Print("未触发突破：收盘价仍在等待区间内");

   // ===== 第六步：入场（止损设为均价）=====
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(bullBreak)
   {
      Print("检测到向上突破，准备评估BUY开仓");
      // 做多：止损在均价下方（均价必须低于当前价才合法）
      double sl = NormalizeDouble(avgClose, _Digits);
      Print("BUY参数检查 | Ask=", DoubleToString(ask, _Digits),
            " | 止损=", DoubleToString(sl, _Digits));
      if(sl >= ask)
      {
         Print("BUY止损位异常：均价(", sl, ") >= 当前Ask(", ask, ")，跳过");
         return;
      }
      if(trade.Buy(InpLotSize, _Symbol, ask, sl, 0, "BOX_BUY"))
         Print("向上突破 BUY | 收盘:", lastClose,
               " 箱顶:", DoubleToString(boxHigh, 2),
               " 突破:", DoubleToString(lastClose - boxHigh, 2), "美金",
               " 止损(均价):", DoubleToString(sl, 2));
   }
   else if(bearBreak)
   {
      Print("检测到向下突破，准备评估SELL开仓");
      // 做空：止损在均价上方（均价必须高于当前价才合法）
      double sl = NormalizeDouble(avgClose, _Digits);
      Print("SELL参数检查 | Bid=", DoubleToString(bid, _Digits),
            " | 止损=", DoubleToString(sl, _Digits));
      if(sl <= bid)
      {
         Print("SELL止损位异常：均价(", sl, ") <= 当前Bid(", bid, ")，跳过");
         return;
      }
      if(trade.Sell(InpLotSize, _Symbol, bid, sl, 0, "BOX_SELL"))
         Print("向下突破 SELL | 收盘:", lastClose,
               " 箱底:", DoubleToString(boxLow, 2),
               " 突破:", DoubleToString(boxLow - lastClose, 2), "美金",
               " 止损(均价):", DoubleToString(sl, 2));
   }
}

//+------------------------------------------------------------------+
//| 检查持仓时间，超过N分钟则强制平仓                                   |
//+------------------------------------------------------------------+
void CheckAndCloseByTime()
{
   datetime now = TimeCurrent();

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      datetime openTime   = (datetime)PositionGetInteger(POSITION_TIME);
      int      holdSeconds = (int)(now - openTime);

      if(holdSeconds >= InpHoldMinutes * 60)
      {
         double profit = PositionGetDouble(POSITION_PROFIT);
         if(trade.PositionClose(ticket))
            Print("⏰ 时间到强制平仓 | Ticket:", ticket,
                  " 持仓:", holdSeconds / 60, "分钟",
                  " 盈亏:", DoubleToString(profit, 2), "美金");
      }
   }
}

//+------------------------------------------------------------------+
//| 统计持仓数量                                                       |
//+------------------------------------------------------------------+
int CountMyPositions()
{
   int count = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetString(POSITION_SYMBOL) == _Symbol &&
         PositionGetInteger(POSITION_MAGIC)  == InpMagicNumber)
         count++;
   }
   return count;
}
